{
    "memory": {
        "interval": 1,
        "format": "{icon} {used:0.1f}/{total:0.1f}G",
        "format-icons": {
            "default": ["<span size='19pt' rise='-4pt'>\u200eמ\u200e</span>"]
        },
        "format-alt": "<span size='19pt' rise='-4pt'>\u200eמ\u200e</span> {}%",
        "tooltip": false
    }
}
